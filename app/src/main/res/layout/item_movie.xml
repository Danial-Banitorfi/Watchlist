<?xml version="1.0" encoding="utf-8"?>
<!-- CardView erzeugt eine weiße Karte mit Schatten und abgerundeten Ecken -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <!-- Ein vertikales Layout, damit Poster oben und Text unten steht (gut für schmale Spalten) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Das Filmbild -->
        <!-- scaleType="centerCrop" schneidet das Bild passend zu, ohne es zu quetschen -->
        <ImageView
            android:id="@+id/iv_poster"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />

        <!-- Container für die Texte (Titel und Jahr) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Der Titel des Films -->
            <!-- ellipsize="end" fügt "..." hinzu, wenn der Titel zu lang für eine Zeile ist -->
            <TextView
                android:id="@+id/tv_movie_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Film Titel" />

            <!-- Das Erscheinungsjahr -->
            <TextView
                android:id="@+id/tv_release_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(2024)"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
